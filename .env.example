# Browser (Vite) — fill these in; they will be bundled into the client
VITE_ANTHROPIC_API_KEY=
VITE_OPENAI_API_KEY=

# Server / backend (Python FastAPI) — only needed if running api/index.py
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=anthropic
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4.1-mini
PHOENIX_UI_URL=http://your-digital-ocean-ip:6006
PHOENIX_COLLECTOR_ENDPOINT=http://your-digital-ocean-ip:6006/v1/traces
PHOENIX_PROJECT_NAME=valon-insurance-claims-demo
